# ── Битрикс24 ────────────────────────────────────────────────────
# Входящий вебхук со скоупом imbot:
# https://your.bitrix24.ru/rest/USER_ID/TOKEN
BITRIX_WEBHOOK=https://b24-qfp5h8.bitrix24.by/rest/10/l8w80i4z3njphprj

# Произвольная строка — секрет бота
BOT_TOKEN=my_secret_bot_token

# ID сотрудника Битрикс24, который получает сообщения
OPERATOR_USER_ID=1

# Публичный URL этого сервера (ngrok для разработки, продакшн домен иначе)
# Битрикс24 будет слать события на WEBHOOK_URL/event
WEBHOOK_URL=https://your-ngrok-url.ngrok.io

# Порт FastAPI сервера
SERVER_PORT=8000

# Путь к SQLite файлу
DB_PATH=contacts.db

# ── Telegram userbot ─────────────────────────────────────────────
# Получить на https://my.telegram.org/apps
TG_API_ID=12345678
TG_API_HASH=abcdef1234567890abcdef1234567890

# Telethon StringSession — получить запустив: uv run get_session.py
TG_SESSION=

# ── Email (IMAP) ─────────────────────────────────────────────────
EMAIL_HOST=imap.gmail.com
EMAIL_PORT=993
EMAIL_USER=your@gmail.com
# Для Gmail использовать App Password: https://myaccount.google.com/apppasswords
EMAIL_PASS=your_app_password
EMAIL_FOLDER=INBOX
# Интервал проверки почты в секундах
EMAIL_POLL_SEC=30
